# ============================================================
# AES Nexys4 DDR — .gitignore
# ============================================================

# Compiled binaries
Baseline-AES/a.out
*.o
*.lnx64.o

# Vivado simulation generated outputs (large binary/cache files)
vivado_sim/**/aes_sim.cache/
vivado_sim/**/aes_sim.sim/sim_1/behav/xsim/xsim.dir/
vivado_sim/**/aes_sim.sim/sim_1/behav/xsim/*.sh
vivado_sim/**/aes_sim.ip_user_files/

# Vivado generated project (rebuild with build.tcl)
*.jou
*.log
*.str
*.pb
*.vdi

# Vivado project directories (fully regenerated by scripts)
# Un-comment below if you want to exclude the vivado_projects dir too
# /vivado_projects/

# IP output products (regenerated by Vivado)
ip_repo/**/*.vds
ip_repo/**/cdc_instrumentation/
ip_repo/**/doc/
ip_repo/**/simulation/
ip_repo/**/synth/
ip_repo/**/impl/

# HLS generated outputs
*.prj/solution*/

# OS
.DS_Store
Thumbs.db

# Python cache
__pycache__/
*.pyc

# Editor
.vscode/
*.swp
